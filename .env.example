# Canonical URL for sitemap/robots (no trailing slash). Example: https://your-domain.com
NEXT_PUBLIC_SITE_URL=

# OpenAI API key — required for LLM-based issues and recommendations.
# Create at https://platform.openai.com/api-keys
# Usage appears at https://platform.openai.com/settings/organization/usage (select the same organization as the key).
OPENAI_API_KEY=
